# Aggron — Variaveis de ambiente
# Copie este arquivo para .env e preencha os valores antes de subir.

# === OBRIGATORIO ===

# Chave secreta para sessoes Flask. Gere uma aleatoria:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=TROCAR_AQUI_COM_CHAVE_ALEATORIA

# Senha do banco PostgreSQL (usada no docker-compose)
DB_PASSWORD=TROCAR_AQUI_SENHA_FORTE

# === OPCIONAL (tem defaults razoaveis) ===

# Ambiente: production ou development (default: development)
FLASK_ENV=production

# URL do banco (default: sqlite:///poolcompras.db em dev)
# Em Docker, o compose ja seta automaticamente — nao precisa mexer.
# DATABASE_URL=postgresql://poolcompras:SENHA@db:5432/poolcompras

# Rodar seed na primeira inicializacao? (default: false)
# Mude para true APENAS na primeira vez. Depois volte para false.
RUN_SEED=false

# Porta do gunicorn (default: 5050)
# PORT=5050

# Workers do gunicorn (default: auto = 2*CPU+1)
# WEB_WORKERS=4